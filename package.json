{
  "name": "vimquest",
  "displayName": "VimQuest",
  "description": "Learn Vim step by step — from baby steps to advanced mastery, with interactive lessons and games",
  "version": "1.0.0",
  "publisher": "vimquest",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "vim",
    "learn vim",
    "vim tutorial",
    "vim game",
    "vim keybindings"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vimquest.openLesson",
        "title": "VimQuest: Open Lesson"
      },
      {
        "command": "vimquest.openGame",
        "title": "VimQuest: Play Game"
      },
      {
        "command": "vimquest.resetProgress",
        "title": "VimQuest: Reset Progress"
      },
      {
        "command": "vimquest.showWelcome",
        "title": "VimQuest: Show Welcome"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vimquest",
          "title": "VimQuest",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "vimquest": [
        {
          "id": "vimquest.lessonsView",
          "name": "Lessons",
          "type": "tree"
        },
        {
          "id": "vimquest.progressView",
          "name": "Your Progress",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "vimquest.openLesson",
          "when": "view == vimquest.lessonsView",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.32.0"
  }
}
