{
  "name": "vimquest",
  "displayName": "VimQuest",
  "description": "Learn Vim step by step \u2014 from baby steps to advanced mastery, with interactive lessons and games",
  "version": "1.3.1",
  "publisher": "Owskar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Owskar/vim-master-extension"
  },
  "bugs": {
    "url": "https://github.com/Owskar/vim-master-extension/issues"
  },
  "homepage": "https://github.com/Owskar/vim-master-extension#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "vim",
    "learn vim",
    "vim tutorial",
    "vim game",
    "vimquest"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vimquest.openLesson",
        "title": "Open Lesson",
        "category": "VimQuest"
      },
      {
        "command": "vimquest.openGame",
        "title": "Play Games",
        "category": "VimQuest",
        "icon": "$(game)"
      },
      {
        "command": "vimquest.showWelcome",
        "title": "Show Dashboard",
        "category": "VimQuest",
        "icon": "$(home)"
      },
      {
        "command": "vimquest.openCheatsheet",
        "title": "Vim Cheat Sheet",
        "category": "VimQuest",
        "icon": "$(list-flat)"
      },
      {
        "command": "vimquest.dailyChallenge",
        "title": "Daily Challenge",
        "category": "VimQuest",
        "icon": "$(calendar)"
      },
      {
        "command": "vimquest.resetProgress",
        "title": "Reset Progress",
        "category": "VimQuest"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vimquest",
          "title": "VimQuest",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "vimquest": [
        {
          "id": "vimquest.lessonsView",
          "name": "Lessons",
          "type": "tree"
        },
        {
          "id": "vimquest.progressView",
          "name": "Your Progress",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vimquest.showWelcome",
          "when": "view == vimquest.lessonsView",
          "group": "navigation"
        },
        {
          "command": "vimquest.openGame",
          "when": "view == vimquest.lessonsView",
          "group": "navigation"
        },
        {
          "command": "vimquest.openCheatsheet",
          "when": "view == vimquest.lessonsView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "package": "npx vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.32.0"
  }
}